{
  "version": 2,
  "builds": [
    {
      "src": "public/index.php",
      "config": {
        "includeFiles": [
          "vendor/**",
          "bootstrap/**",
          "config/**",
          "database/**",
          "resources/**",
          "routes/**",
          "app/**",
          "storage/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production"
  }
}